DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=devhack_game
PORT=4000

# Auth
JWT_SECRET=change_me_super_secret
NODE_ENV=development

# SMTP (optional; if not set, code is logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
# true — если сервер с самоподписным сертификатом (ошибка ESOCKET / self-signed)
SMTP_ALLOW_SELF_SIGNED=false
SMTP_USER=no-reply@syharik.ru
SMTP_PASS=
# Должен совпадать с SMTP_USER или быть разрешённым отправителем (иначе 550 Not allowed sender)
MAIL_FROM=no-reply@syharik.ru

# GigaChat API (чат с ИИ на главной). Ключ из личного кабинета: https://developers.sber.ru/studio/
# Формат: Basic <base64(client_id:client_secret)> или просто строка из кабинета
GIGACHAT_AUTHORIZATION_KEY=

# Telegram bot (привязка аккаунта, синхронизация прогресса). Секрет — одна и та же строка для backend и бота.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=SyharikFinanceBot

TELEGRAM_BOT_SECRET=
API_BASE_URL=http://localhost:4000
# URL сайта для ссылки «продолжить на сайте» в боте
WEB_APP_URL=
# Если API по HTTPS с самоподписным сертификатом — бот не сможет проверить сертификат. Поставь true:
ALLOW_SELF_SIGNED_SSL=false


RECAPTCHA_SECRET_KEY=
VITE_RECAPTCHA_SITE_KEY=